{
  "rules": {
    ".read": false,
    ".write": false,
    "memberships": {
      "$firebaseUid": {
        "$organizationUid": {
          ".read": "auth != null && auth.uid === $firebaseUid",
          ".write": "auth != null && auth.uid === $firebaseUid"
        }
      }
    },
    "organization_members": {
      "$organizationUid": {
        "$firebaseUid": {
          ".read": "auth != null && (auth.uid === $firebaseUid || root.child('memberships/' + auth.uid + '/' + $organizationUid).exists())",
          ".write": "auth != null && auth.uid === $firebaseUid"
        }
      }
    },
    "organizations": {
      "$organizationUid": {
        ".read": "auth != null && root.child('memberships/' + auth.uid + '/' + $organizationUid).exists()",
        ".write": "auth != null && root.child('memberships/' + auth.uid + '/' + $organizationUid).exists()"
      }
    },
    "watchlist": {
      "$organizationUid": {
        ".read": "auth != null && root.child('memberships/' + auth.uid + '/' + $organizationUid).exists()",
        ".write": "auth != null && root.child('memberships/' + auth.uid + '/' + $organizationUid).exists()"
      }
    },
    "drafts": {
      "$organizationUid": {
        ".read": "auth != null && root.child('memberships/' + auth.uid + '/' + $organizationUid).exists()",
        ".write": "auth != null && root.child('memberships/' + auth.uid + '/' + $organizationUid).exists()"
      }
    },
    "grant_sources": {
      ".read": "auth != null",
      ".write": false
    },
    "grants": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
